#
# Copy to `.env` locally (do NOT commit real secrets).
# Docker/ECS should use environment variables (DATABASE_URL, HF_TOKEN).
#

DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DBNAME"
HF_TOKEN="YOUR_HF_TOKEN"

# Allowed CORS origins (comma-separated). Example:
# https://your-vercel-domain.com,http://localhost:3000
CORS_ORIGINS=""

PORT=3001

